generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookStatus {
  WANT_TO_READ
  READING
  FINISHED
}

enum BookFormat {
  PAPER
  EBOOK
  AUDIOBOOK
}

model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  name          String?
  password      String
  currentBookId String?
  books         Book[]
  notes         Note[]
  currentBook   Book?      @relation("CurrentBook", fields: [currentBookId], references: [id], onDelete: SetNull)
}

model Book {
  id            String      @id @default(cuid())
  userId        Int
  title         String
  author        String      @default("")
  coverImageUrl String?
  identifier    String?
  format        BookFormat?
  publisher     String?
  publishedAt   String?
  description   String?
  status        BookStatus  @default(WANT_TO_READ)
  startedAt     DateTime?
  finishedAt    DateTime?
  rating        Int?
  shortReview   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes           Note[]
  currentBookUsers User[] @relation("CurrentBook")

  @@unique([userId, identifier])
  @@index([userId, status])
}

model Note {
  id          String   @id @default(cuid())
  userId      Int
  bookId      String?
  body        String
  quoteText   String?
  locationInfo String?
  actionItems String?
  importance  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book?      @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([bookId])
}

